{
  "_owner": "brain-dump-workflow-pack@1.0.0",
  "hooks": {
    "preToolUse": [
      {
        "command": "${MANAGED_ROOT}/hooks/enforce-state-before-write.sh",
        "matcher": "file_write|file_edit"
      },
      {
        "command": "${MANAGED_ROOT}/hooks/enforce-review-before-push.sh",
        "matcher": "terminal(git push:*)"
      }
    ],
    "postToolUse": [
      {
        "command": "${MANAGED_ROOT}/hooks/link-commit-to-ticket.sh",
        "matcher": "terminal(git commit:*)"
      }
    ]
  }
}

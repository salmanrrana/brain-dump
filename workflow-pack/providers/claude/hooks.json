{
  "_owner": "brain-dump-workflow-pack@1.0.0",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/enforce-state-before-write.sh"
          }
        ]
      },
      {
        "matcher": "Bash(git push:*)",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/enforce-review-before-push.sh"
          }
        ]
      },
      {
        "matcher": "Bash(gh pr create:*)",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/enforce-review-before-push.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(git commit:*)",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/link-commit-to-ticket.sh"
          }
        ]
      },
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/capture-claude-tasks.sh"
          }
        ]
      },
      {
        "matcher": "mcp__brain-dump__workflow",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/spawn-next-ticket.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/hooks/check-for-code-changes.sh"
          }
        ]
      }
    ]
  }
}
